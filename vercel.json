{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/api/v2",
      "dest": "/api/v2.ts",
      "methods": ["GET"]
    },
    {
      "src": "/(.*)",
      "dest": "/"
    }
  ],
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "output": "standalone",
  "env": {
    "NODE_ENV": "production"
  }
}

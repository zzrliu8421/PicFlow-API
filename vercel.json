{ 
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  
  "routes": [
    {
      "src": "/api/v2",
      "dest": "/index.js",
      "methods": ["GET"]
    },
    {
      "src": "/converted/(.*)",
      "dest": "/converted/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.js"
    }
  ],
  "outputDirectory": ".",
  "installCommand": "npm install",
  "buildCommand": "npm run build"
  
}
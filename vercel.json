{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/v2",
      "dest": "/index.js",
      "methods": ["GET"]
    },
    {
      "src": "/converted/(.*)",
      "dest": "/converted/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.js"
    }
  ],
  "outputDirectory": ".",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "env": {
    "NODE_ENV": "production"
  }
}